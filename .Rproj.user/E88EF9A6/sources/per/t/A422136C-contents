#3. Check if the primers orientation is correct for DADA2
# This function creates all orientations of the input sequence
#The Biostrings here works w/ DNAString objects rather than character vectors
#so it needed to get converted
allOrients <- function(primer) {
  require(Biostrings)
  dna <- DNAString(primer) 
  orients <- c(Forward = dna, Complement = complement(dna), Reverse = reverse(dna), 
               RevComp = reverseComplement(dna))
  return(sapply(orients, toString))  # Converts back to character vector
}


FWD.orients <- allOrients(FWD)
