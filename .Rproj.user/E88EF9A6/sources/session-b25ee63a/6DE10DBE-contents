###------Fixes formatting issues that FUNGuild would run in to:----##
# Vector of the rank columns. I'm removing species since I'm analyzing the data at genus level
rank_cols <- c("Kingdom", "Phylum", "Class", "Order", "Family", "Genus")

# Clean NAs, make sure they are character rather than factor
Rtaxa[rank_cols] <- lapply(Rtaxa[rank_cols], function(x) {
  x <- as.character(x)
  x[x %in% c("<NA>", "NA", "")] <- NA
  x
})


# Replace NA with "" so paste won't insert "NA"
Rtaxa[rank_cols] <- lapply(Rtaxa[rank_cols], \(x) ifelse(is.na(x), "", x))

# Collapse multiple delimiters and trim trailing delimiters
collapse_taxonomy <- function(row_vals) {
  s <- paste(row_vals, collapse = ";")
  s <- gsub(";{2,}", ";", s)
  s <- sub("^;+","", s)
  s <- sub(";+$","", s)
  s
}

Rtaxa$Taxonomy <- apply(Rtaxa[, rank_cols, drop = FALSE], 1, collapse_taxonomy)

