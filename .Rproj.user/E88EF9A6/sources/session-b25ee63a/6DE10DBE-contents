##function to simplify to primary guild:
get_primary_guild <- function(x) {
  
  # Missing or empty
  if (is.na(x) || x == "") {
    return(NA_character_)
  }
  
  # Primary guild marked with |
  if (str_detect(x, "\\|")) {
    return(str_extract(x, "(?<=\\|)[^|]+(?=\\|)"))
  }
  
  # Single guild (no delimiters)
  if (!str_detect(x, "-")) {
    return(x)
  }
  
  # Multiple guilds without | → randomly choose one
  guilds <- str_split(x, "-", simplify = TRUE)
  return(sample(guilds, 1))
}

#apply function
set.seed(123) 

#tracks how primary guild was assigned
funguild_primary <- funguild_filtered %>%
  mutate(
    GuildSelection = case_when(
      is.na(guild) | guild == "" ~ "missing",
      str_detect(guild, "\\|") ~ "explicit_primary",
      !str_detect(guild, "-") ~ "single",
      TRUE ~ "random_choice"
    ),
    PrimaryGuild = vapply(guild, get_primary_guild, character(1))
  )


